generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  COMPLETED
  FAILED
  CANCELLED
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  status    CartStatus @default(ACTIVE)
  updatedAt DateTime   @updatedAt @map("updated_at")
  createdAt DateTime   @default(now()) @map("created_at")

  items CartItem[]

  @@index([userId, status], map: "idx_carts_user_status")
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  artworkId String   @map("artwork_id") @db.Uuid
  qty       Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, artworkId], map: "uq_cart_items_cart_artwork")
  @@index([cartId], map: "idx_cart_items_cart_id")
  @@map("cart_items")
}

model Order {
  id                      String      @id @default(uuid()) @db.Uuid
  userId                  String      @map("user_id") @db.Uuid
  status                  OrderStatus @default(PENDING)
  totalAmount             Decimal     @map("total_amount") @db.Decimal(12, 2)
  currency                String      @default("VND")
  shippingAddressSnapshot Json        @map("shipping_address_snapshot")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  items     OrderItem[]
  histories OrderStatusHistory[]

  @@index([userId, createdAt], map: "idx_orders_user_created_at")
  @@index([status], map: "idx_orders_status")
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  artworkId String   @map("artwork_id") @db.Uuid
  qty       Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
}

model OrderStatusHistory {
  id         String      @id @default(uuid()) @db.Uuid
  orderId    String      @map("order_id") @db.Uuid
  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus @map("to_status")
  reason     String
  eventId    String?     @map("event_id")
  createdAt  DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt], map: "idx_order_histories_order_created")
  @@index([eventId], map: "idx_order_histories_event_id")
  @@map("order_status_histories")
}

model ProcessedEvent {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @unique @map("event_id")
  eventType     String   @map("event_type")
  correlationId String   @map("correlation_id")
  processedAt   DateTime @default(now()) @map("processed_at")

  @@index([eventType], map: "idx_processed_events_event_type")
  @@map("processed_events")
}
