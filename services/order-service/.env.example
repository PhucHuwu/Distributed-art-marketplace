SERVICE_PORT=3005
DB_URL=postgresql://postgres:postgres@localhost:5432/distributed_art_marketplace?schema=orders
RABBITMQ_URL=amqp://guest:guest@localhost:5672
JWT_SECRET=replace_with_shared_local_secret
SERVICE_NAME=order-service
RABBITMQ_EXCHANGE=dam.domain.events.v1
RABBITMQ_QUEUE=dam.order-service.v1
RABBITMQ_RETRY_QUEUE=dam.order-service.retry.v1
RABBITMQ_DLQ_QUEUE=dam.order-service.dlq.v1
RABBITMQ_DLX=dam.dlx.v1
RABBITMQ_CONSUME_ROUTING_KEYS=inventory.reserved,inventory.failed,payment.success,payment.failed
RABBITMQ_RETRY_DELAYS_MS=5000,30000,120000
