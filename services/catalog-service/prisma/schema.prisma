generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Artist {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  name        String
  bio         String?
  artworks    Artwork[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("artists")
}

model Artwork {
  id          String            @id @default(uuid()) @db.Uuid
  slug        String            @unique
  title       String
  description String?
  price       Decimal           @db.Decimal(12, 2)
  currency    String            @default("VND")
  artistId    String            @map("artist_id") @db.Uuid
  artist      Artist            @relation(fields: [artistId], references: [id])
  images      ArtworkImage[]
  categories  ArtworkCategory[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([artistId], map: "idx_artworks_artist_id")
  @@index([price], map: "idx_artworks_price")
  @@map("artworks")
}

model ArtworkImage {
  id          String   @id @default(uuid()) @db.Uuid
  artworkId   String   @map("artwork_id") @db.Uuid
  artwork     Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  imageUrl    String   @map("image_url")
  altText     String?  @map("alt_text")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([artworkId], map: "idx_artwork_images_artwork_id")
  @@map("artwork_images")
}

model Category {
  id          String            @id @default(uuid()) @db.Uuid
  slug        String            @unique
  name        String
  description String?
  artworks    ArtworkCategory[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("categories")
}

model ArtworkCategory {
  artworkId   String   @map("artwork_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  artwork     Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assignedAt  DateTime @default(now()) @map("assigned_at")

  @@id([artworkId, categoryId])
  @@index([categoryId], map: "idx_artwork_categories_category_id")
  @@map("artwork_categories")
}
