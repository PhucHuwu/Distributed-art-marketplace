SERVICE_PORT=3007
DB_URL=postgresql://postgres:postgres@localhost:5432/distributed_art_marketplace?schema=notifications
RABBITMQ_URL=amqp://guest:guest@localhost:5672
JWT_SECRET=replace_with_shared_local_secret
SERVICE_NAME=notification-service
RABBITMQ_EXCHANGE=dam.domain.events.v1
RABBITMQ_QUEUE=dam.notification-service.v1
RABBITMQ_ROUTING_KEYS=order.completed,order.failed,payment.failed
RABBITMQ_MAX_RETRY=4
RABBITMQ_RETRY_BACKOFF_MS=5000,30000,120000
RABBITMQ_DLX=dam.dlx.v1
RABBITMQ_DLQ=dam.notification-service.dlq.v1
