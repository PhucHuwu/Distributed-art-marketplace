POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=distributed_art_marketplace
POSTGRES_PORT=5432

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

GATEWAY_PORT=80

JWT_SECRET=replace_with_shared_local_secret

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

AUTH_SERVICE_PORT=3001
USER_PROFILE_SERVICE_PORT=3002
CATALOG_SERVICE_PORT=3003
INVENTORY_SERVICE_PORT=3004
ORDER_SERVICE_PORT=3005
PAYMENT_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
AUDIT_LOG_SERVICE_PORT=3008

AUTH_DB_URL=postgresql://postgres:postgres@postgres:5432/distributed_art_marketplace?schema=auth
USER_PROFILE_DB_URL=postgresql://postgres:postgres@postgres:5432/distributed_art_marketplace?schema=users
CATALOG_DB_URL=postgresql://postgres:postgres@postgres:5432/distributed_art_marketplace?schema=catalog
INVENTORY_DB_URL=postgresql://postgres:postgres@postgres:5432/distributed_art_marketplace?schema=inventory
ORDER_DB_URL=postgresql://postgres:postgres@postgres:5432/distributed_art_marketplace?schema=orders
PAYMENT_DB_URL=postgresql://postgres:postgres@postgres:5432/distributed_art_marketplace?schema=payments
NOTIFICATION_DB_URL=postgresql://postgres:postgres@postgres:5432/distributed_art_marketplace?schema=notifications
AUDIT_LOG_DB_URL=postgresql://postgres:postgres@postgres:5432/distributed_art_marketplace?schema=audit_logs
